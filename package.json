{
  "name": "shin-ai-agent",
  "displayName": "SHIN AI",
  "description": "1\uc778\uae30\uc5c5 AI \uc6cc\ud06c\uc2a4\ud14c\uc774\uc158. \ub85c\uceec AI\ub85c \ucf54\ub529, \uc9c0\uc2dd\uad00\ub9ac, \uc790\ub3d9\ud654\ub97c 24\uc2dc\uac04 \uc6b4\uc601\ud569\ub2c8\ub2e4. Ollama/LM Studio \uae30\ubc18. 100% \uc624\ud504\ub77c\uc778.",
  "version": "1.0.10",
  "publisher": "shin-ai",
  "license": "MIT",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/shin-ai/shin-ai-agent.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Chat"
  ],
  "keywords": [
    "ai",
    "local",
    "ollama",
    "lmstudio",
    "gemma",
    "llama",
    "deepseek",
    "offline",
    "agent",
    "agent-team",
    "second-brain",
    "1\uc778\uae30\uc5c5",
    "solopreneur",
    "code-generation",
    "shin-ai",
    "copilot"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "shin-ai.newChat",
        "title": "SHIN AI: New Chat",
        "icon": "$(add)"
      },
      {
        "command": "shin-ai.openSettings",
        "title": "SHIN AI: \u2699\ufe0f \uc124\uc815 \uc5f4\uae30"
      },
      {
        "command": "shin-ai.exportChat",
        "title": "SHIN AI: Export Chat as Markdown"
      },
      {
        "command": "shin-ai.explainSelection",
        "title": "SHIN AI: Explain Selected Code"
      },
      {
        "command": "shin-ai.focusChat",
        "title": "SHIN AI: Focus Chat Input"
      },
      {
        "command": "shin-ai.showBrainNetwork",
        "title": "SHIN AI: Show Brain Topology \ud83e\udde0"
      },
      {
        "command": "shin-ai.changeCompanyDir",
        "title": "SHIN AI: \ud68c\uc0ac \ud3f4\ub354 \ubcc0\uacbd \ud83c\udfe2"
      },
      {
        "command": "shin-ai.connectCompanyRepo",
        "title": "SHIN AI: \ud68c\uc0ac GitHub \uc5f0\uacb0 \u2601\ufe0f"
      },
      {
        "command": "shin-ai.connectGoogleCalendarWrite",
        "title": "SHIN AI: Google Calendar \uc790\ub3d9 \uc77c\uc815 \uc5f0\uacb0 \ud83d\udcc5"
      },
      {
        "command": "shinAi.tasks.refresh",
        "title": "\ud560 \uc77c \uc0c8\ub85c\uace0\uce68",
        "category": "SHIN AI",
        "icon": "$(refresh)"
      },
      {
        "command": "shinAi.tasks.markDone",
        "title": "완료 처리",
        "category": "SHIN AI",
        "icon": "$(check)"
      },
      {
        "command": "shinAi.tasks.cancel",
        "title": "취소",
        "category": "SHIN AI",
        "icon": "$(close)"
      },
      {
        "command": "shinAi.tasks.setPriority",
        "title": "우선순위 변경",
        "category": "SHIN AI",
        "icon": "$(arrow-up)"
      },
      {
        "command": "shinAi.tasks.openTrackerJson",
        "title": "tracker.json \uc5f4\uae30",
        "category": "SHIN AI",
        "icon": "$(file-code)"
      },
      {
        "command": "shinAi.dailyBriefing.fireNow",
        "title": "\uc9c0\uae08 \ub370\uc77c\ub9ac \ube0c\ub9ac\ud551 \ubc1c\uc0ac",
        "category": "SHIN AI",
        "icon": "$(megaphone)"
      },
      {
        "command": "shinAi.diagnoseConnection",
        "title": "\ud83d\udd0d LLM \uc5f0\uacb0 \uc9c4\ub2e8 (Ollama / LM Studio)",
        "category": "SHIN AI",
        "icon": "$(pulse)"
      },
      {
        "command": "shinAi.youtube.refreshCommentQueue",
        "title": "YouTube \ub313\uae00 \ub2f5\uc7a5 \ud050 \uac31\uc2e0",
        "category": "SHIN AI",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "shinAi.developer.scaffoldProject",
        "title": "Developer: \uc0c8 \ud504\ub85c\uc81d\ud2b8 \ub9cc\ub4e4\uae30",
        "category": "SHIN AI",
        "icon": "$(file-directory-create)"
      },
      {
        "command": "shinAi.skill.saveLast",
        "title": "\ubc29\uae08 \uc0b0\ucd9c\ubb3c \u2192 \uc2a4\ud0ac\ub85c \uc800\uc7a5 \ud83d\udc8e",
        "category": "SHIN AI",
        "icon": "$(star)"
      },
      {
        "command": "shinAi.youtube.connectOAuth",
        "title": "YouTube OAuth \uc5f0\uacb0 (Analytics)",
        "category": "SHIN AI",
        "icon": "$(plug)"
      },
      {
        "command": "shinAi.dashboard.open",
        "title": "시스템 진단",
        "category": "SHIN AI",
        "icon": "$(organization)"
      },
      {
        "command": "shinAi.apiConnections.open",
        "title": "\uc678\ubd80 \uc5f0\uacb0 (API \ud0a4 \ud55c \uacf3\uc5d0\uc11c)",
        "category": "SHIN AI",
        "icon": "$(plug)"
      },
      {
        "command": "shinAi.revenueDashboard.open",
        "title": "\ud83d\udcb0 \ub9e4\ucd9c \ub300\uc2dc\ubcf4\ub4dc (PayPal \uc2e4\uc2dc\uac04)",
        "category": "SHIN AI",
        "icon": "$(graph-line)"
      }
    ],
    "keybindings": [
      {
        "command": "shin-ai.focusChat",
        "key": "cmd+l",
        "mac": "cmd+l"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "shin-ai.explainSelection",
          "when": "editorHasSelection",
          "group": "1_modification"
        }
      ],
      "view/title": [
        {
          "command": "shinAi.tasks.refresh",
          "when": "view == shinAi.tasks",
          "group": "navigation"
        },
        {
          "command": "shinAi.tasks.openTrackerJson",
          "when": "view == shinAi.tasks",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "shinAi.tasks.markDone",
          "when": "view == shinAi.tasks && viewItem == openTask",
          "group": "inline@1"
        },
        {
          "command": "shinAi.tasks.cancel",
          "when": "view == shinAi.tasks && viewItem == openTask",
          "group": "inline@2"
        },
        {
          "command": "shinAi.tasks.setPriority",
          "when": "view == shinAi.tasks && viewItem == openTask",
          "group": "1_actions"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "shin-ai-sidebar",
          "title": "SHIN AI",
          "icon": "assets/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "shin-ai-sidebar": [
        {
          "type": "webview",
          "id": "shin-ai-chat-view",
          "name": "SHIN AI Chat"
        }
      ]
    },
    "configuration": {
      "title": "SHIN AI",
      "properties": {
        "shinAi.ollamaUrl": {
          "type": "string",
          "default": "http://127.0.0.1:11434",
          "description": "\ud83e\udd16 AI \uc11c\ubc84 \uc8fc\uc18c (\ubcf4\ud1b5 \uc790\ub3d9\uc73c\ub85c \uc7a1\ud788\ub2c8 \uac74\ub4dc\ub9ac\uc9c0 \uc54a\uc544\ub3c4 \ub429\ub2c8\ub2e4)"
        },
        "shinAi.pythonPath": {
          "type": "string",
          "default": "",
          "description": "\ud83d\udc0d Python 3 \uc2e4\ud589 \uba85\ub839/\uc808\ub300 \uacbd\ub85c (\ube44\uc6b0\uba74 \uc790\ub3d9 \uac10\uc9c0). \ub3c4\uad6c \uc2e4\ud589 'exit 1' \ub610\ub294 'Python was not found' \uc5d0\ub7ec \uc2dc \uc5ec\uae30\uc5d0 \uc9c1\uc811 \uc9c0\uc815. \uc708\ub3c4\uc6b0 \uc608: 'py -3' \ub610\ub294 'C:\\\\Python311\\\\python.exe'. \ub9e5 \uc608: '/opt/homebrew/bin/python3' \ub610\ub294 'python3'. \ubcc0\uacbd \ud6c4 \uc548\ud2f0\uadf8\ub798\ube44\ud2f0 \uc7ac\uc2dc\uc791."
        },
        "shinAi.defaultModel": {
          "type": "string",
          "default": "",
          "description": "\ud83e\udde0 \uc0ac\uc6a9\ud560 AI \ubaa8\ub378 \uc774\ub984 (\ube44\uc6cc\ub450\uba74 \uc124\uce58\ub41c \ubaa8\ub378 \uc911 \uac00\uc7a5 \uc791\uc740 \uac83\uc774 \uc790\ub3d9 \uc120\ud0dd\ub428. \uc9c1\uc811 \uc9c0\uc815 \uc608: llama3.2:1b, gemma2:2b, qwen2.5:1.5b)"
        },
        "shinAi.requestTimeout": {
          "type": "number",
          "default": 300,
          "description": "\u23f1 AI \uc751\ub2f5 \ub300\uae30 \uc2dc\uac04 (\ucd08, \uae30\ubcf8 300\ucd08 = 5\ubd84)"
        },
        "shinAi.streamFirstTokenTimeoutSec": {
          "type": "number",
          "default": 240,
          "description": "\ud83d\udc22 \ubaa8\ub378 \uccab \ud1a0\ud070\uae4c\uc9c0 \uae30\ub2e4\ub9ac\ub294 \uc2dc\uac04 (\ucd08). \uc800\uc0ac\uc591 \uba38\uc2e0\uc740 \ubaa8\ub378 \ub85c\ub4dc\uc5d0 \uc2dc\uac04 \uac78\ub824\uc11c 60\ucd08 \uc548\uc5d0 \uccab \uc751\ub2f5 \ubabb \uc634. \uae30\ubcf8 240\ucd08(4\ubd84). 600\ucd08(10\ubd84)\uae4c\uc9c0 \ub298\ub824\ub3c4 OK."
        },
        "shinAi.streamIdleTimeoutSec": {
          "type": "number",
          "default": 60,
          "description": "\ud83d\udca4 \uccab \uc751\ub2f5 \uc774\ud6c4 \ud1a0\ud070 \uc0ac\uc774 \ucd5c\ub300 idle \uc2dc\uac04 (\ucd08). \ud55c \ubc88 \uc751\ub2f5 \uc2dc\uc791\ud558\uba74 \ubcf4\ud1b5 \ube60\ub974\uac8c \ud758\ub7ec\uc11c 60\ucd08\uba74 \ucda9\ubd84. \ubaa8\ub378 hang \uac10\uc9c0\uc6a9."
        },
        "shinAi.localBrainPath": {
          "type": "string",
          "default": "",
          "description": "\ud83d\udcc1 \ub0b4 \uc9c0\uc2dd \ud3f4\ub354 \uacbd\ub85c \u2014 \ub0b4 PC\uc758 \ud2b9\uc815 \ud3f4\ub354(\uc608: \ubc14\ud0d5\ud654\uba74/MyBrain)\ub97c \uc9c0\uc815\ud558\uba74, \uadf8 \uc548\uc758 .md \ud30c\uc77c\ub4e4\uc774 AI\uc758 \uc9c0\uc2dd\uc774 \ub429\ub2c8\ub2e4. \ube44\uc6cc\ub450\uba74 \uae30\ubcf8 \ud3f4\ub354\ub97c \uc790\ub3d9 \uc0dd\uc131\ud569\ub2c8\ub2e4."
        },
        "shinAi.secondBrainRepo": {
          "type": "string",
          "default": "",
          "description": "\ud83d\udd17 \ub450\ub1cc \uae43\ud5c8\ube0c \uc800\uc7a5\uc18c URL \u2014 \ub0b4 \uc9c0\uc2dd\uc744 \ud074\ub77c\uc6b0\ub4dc\uc5d0 \ubc31\uc5c5\ud558\uace0 \ub3d9\uae30\ud654\ud560 \uae43\ud5c8\ube0c \uc800\uc7a5\uc18c \uc8fc\uc18c. (\uc608: https://github.com/\uc0ac\uc6a9\uc790/memory)"
        },
        "shinAi.companyRepo": {
          "type": "string",
          "default": "",
          "description": "\ud83d\udd17 \ud68c\uc0ac \uae43\ud5c8\ube0c \uc800\uc7a5\uc18c URL \u2014 \ud68c\uc0ac \ud3f4\ub354\ub97c \ub450\ub1cc\uc640 \ubcc4\ub3c4 \uc800\uc7a5\uc18c\ub85c \ubc31\uc5c5\ud560 \ub54c \uc0ac\uc6a9. \ud68c\uc0ac \ud3f4\ub354\uac00 \ub450\ub1cc \uc548 nested\uba74(\uae30\ubcf8) \ube44\uc6cc\ub450\uc138\uc694(\uc774\ubbf8 \ub450\ub1cc repo\uc5d0 \uac19\uc774 \ub4e4\uc5b4\uac10). \ud68c\uc0ac\ub97c \ubcc4\ub3c4 \uc704\uce58(detached)\ub85c \ubd84\ub9ac\ud55c \uacbd\uc6b0\uc5d0\ub9cc \uc758\ubbf8 \uc788\uc74c. \uba85\ub839 \ud314\ub808\ud2b8\uc758 'Connect AI: \ud68c\uc0ac GitHub \uc5f0\uacb0'\ub85c\ub3c4 \uc124\uc815."
        },
        "shinAi.companyDir": {
          "type": "string",
          "default": "",
          "description": "\ud83d\udc54 \ud68c\uc0ac \ud3f4\ub354 \uacbd\ub85c \u2014 \ube44\uc6cc\ub450\uba74 \ub450\ub1cc \ud3f4\ub354 \uc548 _company/\uc5d0 \uc790\ub3d9 \uc0dd\uc131\ub429\ub2c8\ub2e4(\uc2dc\uac01\uc801\uc73c\ub85c \ubd84\ub9ac\u00b7\ud55c git repo). \uc808\ub300 \uacbd\ub85c \ub610\ub294 ~/\ub85c \uc2dc\uc791\ud558\ub294 \uacbd\ub85c\ub97c \uc785\ub825\ud558\uba74 \ub450\ub1cc\uc640 \uc644\uc804\ud788 \ubd84\ub9ac\ub41c \ubcc4\ub3c4 \uc704\uce58\uc5d0 \ud68c\uc0ac \ud3f4\ub354\uac00 \ub9cc\ub4e4\uc5b4\uc9d1\ub2c8\ub2e4(\uc608: \uc678\uc8fc \uacf5\uc720\uc6a9\u00b7\ub2e4\ub978 git repo). \uba85\ub839 \ud314\ub808\ud2b8\uc758 'Connect AI: \ud68c\uc0ac \ud3f4\ub354 \ubcc0\uacbd'\uc73c\ub85c\ub3c4 \uc124\uc815 \uac00\ub2a5."
        },
        "shinAi.assetsPath": {
          "type": "string",
          "default": "",
          "description": "\ud83c\udfa8 (\uc120\ud0dd) LimeZu Modern Interiors \ud480\ud329 \ud3f4\ub354 \u2014 \uc0ac\ubb34\uc2e4 \ubdf0\uc5d0 \ub354 \ud48d\ubd80\ud55c \uce90\ub9ad\ud130\u00b7\uc778\ud14c\ub9ac\uc5b4\ub97c \uc4f0\uace0 \uc2f6\uc744 \ub54c\ub9cc \uc9c0\uc815\ud569\ub2c8\ub2e4. \ube44\uc6cc\ub450\uba74 vsix\uc5d0 \ubc88\ub4e4\ub41c 7\uac1c \uce90\ub9ad\ud130\ub97c \uc790\ub3d9 \uc0ac\uc6a9\ud569\ub2c8\ub2e4."
        },
        "shinAi.autoCycleEnabled": {
          "type": "boolean",
          "default": true,
          "description": "\ud83e\udd16 24\uc2dc\uac04 \uc790\uc728 \uc0ac\uc774\ud074 \u2014 \ucf1c\ub450\uba74 \uc0ac\uc6a9\uc790\uac00 30\ubd84 \uc774\uc0c1 \uc790\ub9ac\ub97c \ube44\uc6e0\uc744 \ub54c CEO\uac00 \ud68c\uc0ac \ubaa9\ud45c\u00b7\uac01 \uc5d0\uc774\uc804\ud2b8 \uac1c\uc778 \ubaa9\ud45c\ub97c \uac80\ud1a0\ud574 \uc790\ub3d9\uc73c\ub85c \ub2e4\uc74c \ud55c \uc2a4\ud15d\uc744 \uc2e4\ud589\ud569\ub2c8\ub2e4. \uc5d0\uc774\uc804\ud2b8 \ud328\ub110\uc758 \ud1a0\uae00\uc5d0\uc11c \uac19\uc774 \uc81c\uc5b4\ub429\ub2c8\ub2e4."
        },
        "shinAi.dailyBriefingTime": {
          "type": "string",
          "default": "09:00",
          "description": "\ud83d\udccb \ub9e4\uc77c \uc790\ub3d9 \ub370\uc77c\ub9ac \ube0c\ub9ac\ud551 \ubc1c\uc0ac \uc2dc\uac01 (HH:MM, 24\uc2dc\uac04 \ud615\uc2dd). \ube44\uc6cc\ub450\uac70\ub098 'off'\ub85c \uc124\uc815\ud558\uba74 \uc790\ub3d9 \ubc1c\uc0ac \uc548 \ud568. \ud154\ub808\uadf8\ub7a8\uc73c\ub85c \uc624\ub298 \uc77c\uc815\u00b7\ud560 \uc77c\u00b7\uc5b4\uc81c \ud68c\uc0ac \ud65c\ub3d9 \uce74\ub4dc\uac00 \uc804\uc1a1\ub429\ub2c8\ub2e4."
        },
        "shinAi.secretaryBridgeMode": {
          "type": "string",
          "enum": [
            "off",
            "output_only",
            "full"
          ],
          "enumDescriptions": [
            "Off \u2014 \ube44\uc11c\ub294 \ud154\ub808\uadf8\ub7a8\uc5d0\uc11c\ub9cc \ud65c\ub3d9. \uc0ac\uc774\ub4dc\ubc14\ub294 CEO\uc640 \uc9c1\uc811 \ub300\ud654 (\ud604\uc7ac \ub3d9\uc791)",
            "\ucd9c\ub825\ub9cc \u2014 specialist \uc0b0\ucd9c\ubb3c \ub05d\uc5d0 \ube44\uc11c\uac00 \ud55c \uc904\ub85c \uc0ac\uc7a5\ub2d8\uaed8 \uc815\ub9ac \uce74\ub4dc \ucd94\uac00",
            "\ud480 \ube0c\ub9bf\uc9c0 \u2014 \uc0ac\uc774\ub4dc\ubc14 \uc785\ub825\ub3c4 \ube44\uc11c\uac00 1\ucc28 \uc218\uc2e0 \ud6c4 CEO\uc5d0\uac8c \ub77c\uc6b0\ud305 \ub610\ub294 \uc9c1\uc811 \uc751\ub2f5"
          ],
          "default": "off",
          "description": "\ud83d\udcf1 \ube44\uc11c \ube0c\ub9bf\uc9c0 \ubaa8\ub4dc \u2014 \ube44\uc11c\ub97c \uc0ac\ub78c\uacfc AI \ud68c\uc0ac \uc0ac\uc774\uc758 \ub2e8\uc77c \ud1b5\ub85c\ub85c \ub9cc\ub4e4\uc9c0 \uacb0\uc815. \ucc28\uc774\ub97c \uc9c1\uc811 \uccb4\uac10\ud558\uba74\uc11c \uba40\ud2f0\uc5d0\uc774\uc804\ud2b8 \ub77c\uc6b0\ud305 \ud328\ud134\uc744 \ud559\uc2b5\ud560 \uc218 \uc788\uc5b4\uc694."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "esbuild src/extension.ts --bundle --platform=node --external:vscode --outfile=out/extension.js",
    "compile-tests": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run compile-tests",
    "test": "node ./out/test/runTest.js",
    "test:unit": "mocha out/test/suite/*.test.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "@vercel/ncc": "^0.38.4",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "jsdom": "^29.0.2"
  }
}